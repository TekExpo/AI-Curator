  },
  "name": {
    "short": "AI Curator",
    "full": "AI Curator - Article Recommender"
  },
  "description": {
    "short": "AI-powered personalised article recommendations.",
    "full": "AI Curator delivers personalised article recommendations based on your interests, lets you save articles, and share them directly to Viva Engage communities."
  },
  "accentColor": "#107C10",
  "staticTabs": [
    {
